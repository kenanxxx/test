# Solana RPC Endpoint (isteğe bağlı)
# Boş bırakılırsa public endpoint kullanılır
# Önerilen: Helius, QuickNode, Alchemy gibi servisler
# ÖNEMLİ: Public RPC yeterli değil! ACIL_COZUM.md dosyasını okuyun
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Market Cap Aralığı (USD)
MIN_MCAP=100000
MAX_MCAP=10000000

# Takip edilecek cüzdanlar (virgülle ayrılmış)
# Format 1: emoji|isim|adres (önerilen)
# Format 2: isim|adres
# Format 3: sadece adres
# 
# Örnekler:
# WALLETS=💎|Whale Hunter|7YttLkHDoNj9wyDur5pM1ejNaAvT9X4eqaYcHQqtj2G5,🔥|Smart Trader|HN7cABqLq46Es1jh92dQQisAq662SmxELLLsHHe4YWrH
# WALLETS=My Wallet|6pkpMrR9Unic4hCCY9NbjW3TRKAQh132ThcsLDBBtKGD
# WALLETS=4VR5eVLqnqvHZASaGVyUjSY67U7hHgFAqyhAHPNK2pbs
WALLETS=

# Web UI Ayarları
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Polling interval (saniye) - İşlemleri kontrol etme sıklığı
# 1-3 saniye = Çok hızlı (RPC limiti riskli)
# 5 saniye = Hızlı (önerilen)
# 10+ saniye = Yavaş ama güvenli
POLL_INTERVAL=5

# Cache süresi (saniye)
CACHE_DURATION=300
