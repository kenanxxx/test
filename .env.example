# Solana RPC Endpoint (isteğe bağlı)
# Boş bırakılırsa public endpoint kullanılır
# Önerilen: Helius, QuickNode, Alchemy gibi servisler
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Market Cap Aralığı (USD)
MIN_MCAP=100000
MAX_MCAP=10000000

# Takip edilecek cüzdanlar (virgülle ayrılmış)
# Örnek: WALLETS=wallet1,wallet2,wallet3
WALLETS=

# Web UI Ayarları
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Polling interval (saniye)
POLL_INTERVAL=10

# Cache süresi (saniye)
CACHE_DURATION=300
